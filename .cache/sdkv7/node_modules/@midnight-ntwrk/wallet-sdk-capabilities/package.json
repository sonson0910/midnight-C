{
  "name": "@midnight-ntwrk/wallet-sdk-capabilities",
  "version": "3.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Midnight Foundation",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/midnight-ntwrk/artifacts.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./balancer": {
      "types": "./dist/balancer/index.d.ts",
      "import": "./dist/balancer/index.js"
    },
    "./submission": {
      "types": "./dist/submission/index.d.ts",
      "import": "./dist/submission/index.js"
    },
    "./pendingTransactions": {
      "types": "./dist/pendingTransactions/index.d.ts",
      "import": "./dist/pendingTransactions/index.js"
    },
    "./proving": {
      "types": "./dist/proving/index.d.ts",
      "import": "./dist/proving/index.js"
    }
  },
  "dependencies": {
    "@midnight-ntwrk/ledger-v7": "^7.0.2",
    "@midnight-ntwrk/wallet-sdk-abstractions": "^2.0.0",
    "@midnight-ntwrk/wallet-sdk-indexer-client": "^1.1.0",
    "@midnight-ntwrk/wallet-sdk-node-client": "^1.0.1",
    "@midnight-ntwrk/wallet-sdk-prover-client": "^1.1.0",
    "@midnight-ntwrk/wallet-sdk-utilities": "^1.0.1",
    "@midnight-ntwrk/zkir-v2": "^2.1.0",
    "effect": "^3.19.19",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@effect/cluster": "^0.56.4",
    "@effect/experimental": "^0.58.0",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@effect/rpc": "^0.73.2",
    "@effect/sql": "^0.49.0",
    "@effect/workflow": "^0.16.0"
  },
  "scripts": {
    "typecheck": "tsc -b ./tsconfig.json --noEmit --force",
    "test": "vitest run",
    "lint": "eslint --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,yaml,yml,md}\"",
    "dist": "tsc -b ./tsconfig.build.json",
    "dist:publish": "tsc -b ./tsconfig.publish.json",
    "clean": "rimraf --glob dist 'tsconfig.*.tsbuildinfo' && date +%s > .clean-timestamp",
    "publint": "publint --strict"
  }
}
